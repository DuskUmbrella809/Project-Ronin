#!/bin/bash

clear

echo "══════════════════════════════════════"
echo "        🚀 PROJECT RONIN SHIP"
echo "══════════════════════════════════════"
echo

# Make sure we're inside a Git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "❌ Not inside a Git repository."
    exit 1
fi

# Show current branch
BRANCH=$(git branch --show-current)
echo "🌿 Branch: $BRANCH"
echo

# Get commit message
read -p "📝 Commit message: " MESSAGE

# Don't allow empty commit messages
if [[ -z "$MESSAGE" ]]; then
    echo
    echo "❌ Commit cancelled."
    exit 1
fi

echo
echo "📦 Staging files..."

if git add .; then
    echo "   ✅ Files staged."
else
    echo "   ❌ Failed to stage files."
    exit 1
fi

echo
echo "💾 Creating commit..."

if git commit -m "$MESSAGE"; then
    echo "   ✅ Commit created."
else
    echo "   ❌ Commit failed."
    exit 1
fi

echo
echo "☁️ Pushing to GitHub..."

if git push; then
    echo
    echo "══════════════════════════════════════"
    echo "        ✅ SHIP COMPLETE!"
    echo "══════════════════════════════════════"
    echo
    echo "🚀 Project synchronized with GitHub."
else
    echo
    echo "❌ Push failed."
    exit 1
fi