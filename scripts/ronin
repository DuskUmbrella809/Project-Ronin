#!/bin/bash
source "$(dirname "$0")/../modules/weather.sh"
# Tokyo Night Colors

RESET="\e[0m"

BLUE="\e[38;5;110m"
PURPLE="\e[38;5;141m"
GREEN="\e[38;5;114m"
RED="\e[38;5;203m"
YELLOW="\e[38;5;180m"
CYAN="\e[38;5;117m"
GRAY="\e[38;5;245m"
WHITE="\e[97m"


get_system_info() {

    USER_NAME=$(whoami)
    HOST_NAME=$(hostname)

    VERSION=$(cat ~/Projects/Project-Ronin/VERSION)

    OS_NAME=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')

    BATTERY=$(cat /sys/class/power_supply/BAT*/capacity 2>/dev/null)

    MEMORY=$(free -h | awk '/Mem:/ {print $3 " / " $2}')

    CURRENT_DIR=$(pwd)

    DISK=$(df -h / | awk 'NR==2 {print $5}')

    TIME=$(date +"%I:%M %p")

    UPTIME=$(uptime -p | sed 's/up //')

    LOCAL_IP=$(hostname -I | awk '{print $1}')

    DOCKER_COUNT=$(docker ps -q 2>/dev/null | wc -l)

    if ping -c1 1.1.1.1 >/dev/null 2>&1
    then
        INTERNET="🟢 Online"
    else
        INTERNET="🔴 Offline"
    fi

    if systemctl is-active --quiet ollama
    then
        OLLAMA="🟢 Running"
    else
        OLLAMA="🔴 Stopped"
    fi
get_git_status
}
get_git_status() {

    if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then

        if [[ -z $(git status --porcelain) ]]; then
            GIT_STATUS="✅ Clean"
        else
            CHANGES=$(git status --porcelain | wc -l)
            GIT_STATUS="⚠️ ${CHANGES} Changes"
        fi

    else
        GIT_STATUS="N/A"
    fi

}
show_header() {

    get_system_info

    clear

echo "╔════════════════════════════════════════════════════════════════════╗"
echo -e "║${PURPLE}                      PROJECT RONIN${RESET}                                 ║"
echo -e "║${GRAY}                          v${VERSION}${RESET}                                    ║"
echo "╠════════════════════════════════════════════════════════════════════╣"

    printf "║ 👤 User        %-48s║\n" "$USER_NAME"
    printf "║ 💻 Host        %-48s║\n" "$HOST_NAME"
    printf "║ 🕒 Time        %-48s║\n" "$TIME"
    printf "║ 🐧 OS          %-48s║\n" "$OS_NAME"
    printf "║ 🔋 Battery     %-48s║\n" "${BATTERY}%"
    printf "║ 🌐 Internet    %-48s║\n" "$INTERNET"   
    printf "║ 🧠 Memory      %-48s║\n" "$MEMORY"
    printf "║ 💾 Disk        %-48s║\n" "$DISK"
    printf "║ 🐳 Containers  %-48s║\n" "$DOCKER_COUNT"
    printf "║ 🤖 Ollama      %-48s║\n" "$OLLAMA"
    printf "║ 🌿 Git Status  %-48s║\n" "$GIT_STATUS"
    printf "║ 📡 Local IP    %-48s║\n" "$LOCAL_IP"
    printf "║ ⏱ Uptime      %-48s║\n" "$UPTIME"
    printf "║ 📁 Directory   %-48s║\n" "$CURRENT_DIR"

    echo "╚════════════════════════════════════════════════════════════════════╝"
    echo

}

show_menu() {

    echo "╭──────────────────────── QUICK ACTIONS ───────────────────────╮"
    echo "│                                                              │"
    echo "│   [1] 🩺 Doctor              [5] 📝 Notes                    │"
    echo "│   [2] 🌐 Network             [6] ☁️  Weather                  │"
    echo "│   [3] 🤖 AI                  [7] 📚 Learn                    │"
    echo "│   [4] 🐳 Docker              [8] ⚙️  Settings                 │"
    echo "│                                                              │"
    echo "│                        [Q] Quit                              │"
    echo "╰──────────────────────────────────────────────────────────────╯"
    echo
}

pause() {
    echo
    read -p "Press Enter to continue..."
}

while true
do

    show_header
    show_menu

    read -rsn1 choice

    case $choice in

        1)
            doctor
            pause
            ;;

        2)
            network
            pause
            ;;

        3)
            echo
            echo "🤖Launching Open WebUI..."
            xdg-open "http://localhost:8080" >/dev/null 2>&1
            pause
            ;;

        4)
            clear
            echo
            echo "🐳 Running Containers..."
            echo "------------------------"
            docker ps --format "table {{.Names}}\t{{.Status}}"
            echo
            pause
            ;;

        5)
            clear
            echo
            echo "══════════════════════════════════════"
            echo "         📝 RONIN NOTES"
            echo "══════════════════════════════════════"
            echo
            echo "🚀 Opening Ronin Vault..."

            if [ -f "$HOME/Applications/Obsidian.AppImage" ]; then
            "$HOME/Applications/Obsidian.AppImage" --no-sandbox "$HOME/Documents/Ronin" >/dev/null 2>&1 &
            echo "✅ Vault launched."
            else
            echo "❌ Obsidian AppImage not found."
            fi

            pause
            ;;
            
            
            
    

        6)
           clear

            echo "══════════════════════════════════════"
            echo "          ☀️ RONIN WEATHER"
            echo "══════════════════════════════════════"
            echo

            # Detect current location
            DISPLAY_CITY=$(curl -s ipinfo.io/city)
            CITY=$(echo "$DISPLAY_CITY" | sed 's/ /+/g')
            REGION=$(curl -s ipinfo.io/region)

            echo "📍 $DISPLAY_CITY, $REGION"
            echo

            # Fetch weather data
            WEATHER=$(curl -s "wttr.in/${CITY}?format=%t|%f|%h|%w|%C|%u")

         if [ -z "$WEATHER" ]; then
            echo "❌ Unable to retrieve weather data."
            echo
            pause
         fi

         TEMP=$(echo "$WEATHER" | cut -d'|' -f1)
         FEELS=$(echo "$WEATHER" | cut -d'|' -f2)
         HUMIDITY=$(echo "$WEATHER" | cut -d'|' -f3)
         WIND=$(echo "$WEATHER" | cut -d'|' -f4)
         CONDITION=$(echo "$WEATHER" | cut -d'|' -f5)
         UV=$(echo "$WEATHER" | cut -d'|' -f6 | tr -d '%')

         printf "🌡️  Temperature : %s\n" "$TEMP"
         printf "🥵 Feels Like  : %s\n" "$FEELS"
         printf "☁️  Conditions : %s\n" "$CONDITION"
         printf "💧 Humidity    : %s\n" "$HUMIDITY"
         printf "💨 Wind        : %s\n" "$WIND"
         printf "☀️  UV Index    : %s\n" "$UV"

        echo

        # UV Recommendation
       if [[ "$UV" =~ ^[0-9]+$ ]]; then
        if (( UV >= 11 )); then
            echo "🟣 UV Level: Extreme"
            echo "🧴 Avoid prolonged sun exposure."
        elif (( UV >= 8 )); then
            echo "🔴 UV Level: Very High"
            echo "🧴 Wear sunscreen and sunglasses."
        elif (( UV >= 6 )); then
            echo "🟠 UV Level: High"
            echo "😎 Sun protection is recommended."
        elif (( UV >= 3 )); then
            echo "🟡 UV Level: Moderate"
            echo "🌤️ Consider sunscreen if outside."
        else
            echo "🟢 UV Level: Low"
            echo "👍 Minimal sun protection needed."
        fi
        fi

         echo
         echo "══════════════════════════════════════"
         echo

         pause
         ;;
            
            
            
            

        7)
            clear

            echo "══════════════════════════════════════"
            echo "         📚 RONIN ACADEMY"
            echo "══════════════════════════════════════"
            echo
            echo "💡 Command of the Day"
            echo
            echo "Command:"
            echo "grep"
            echo
            echo "Description:"
            echo "Search text for words or patterns."
            echo
            echo "Example:"
            echo 'grep "error" logfile.txt'
            echo
            echo "Today's Challenge:"
            echo "Find every .conf file in /etc"
            echo "that contains the word \"listen\"."
            echo
            echo "Hint:"
            echo 'grep -R "listen" /etc'
            echo

           pause
           ;;
            
            
            
            

        8)
            echo
            echo "Update module coming soon."
            pause
            ;;

        9)
            echo
            echo "Backup module coming soon."
            pause
            ;;

        q|Q)
            clear
            echo "Goodbye, Alex."
            exit 0
            ;;

        *)
            echo
            echo "Invalid option."
            pause
            ;;

    esac

done